{
  "name": "trrbot-ts-bolt",
  "version": "2.0.11",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "vite build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky || true"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "Slack Bolt アプリケーション（TypeScript）",
  "dependencies": {
    "@slack/bolt": "^4.7.2",
    "better-sqlite3": "^12.10.0",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.19",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
